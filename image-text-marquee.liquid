{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mob }}px;
    padding-bottom: {{ section.settings.padding_bottom_mob }}px;
    {% if section.settings.show_top_border %}border-top: 1px solid #E6E6E6;{% endif %}
    {% if section.settings.show_bottom_border %}border-bottom: 1px solid #E6E6E6;{% endif %}
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #marquee-{{ section.id }} .marquee-track {
    {% if section.settings.direction == 'right' %}
      animation-direction: reverse;
    {% endif %}
  }
  .marquee-section {
    width: 100%;
    overflow: hidden;
  }
  
  .marquee-wrapper {
    position: relative;
    overflow: hidden;
    width: 100%;
  }
  
  .marquee-track {
    display: flex;
    align-items: center;
    white-space: nowrap;
    width: max-content;
    will-change: transform;
    animation: marquee-scroll var(--marquee-speed, 18s) linear infinite;
  }
  
  .marquee-set {
    display: flex;
    align-items: center;
    gap: 60px;
    padding-right: 60px; /* matches gap so seam is invisible */
    flex-shrink: 0;
  }
  
  .marquee-item {
    display: flex;
    align-items: center;
    gap: 15px;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
  }
  
  .marquee-item img {
    width: 70px;
    height: 70px;
    object-fit: contain;
    flex-shrink: 0;
  }
  
  .marquee-item span {
    font-size: 30px;
    text-transform: uppercase;
    font-family: serif;
    color: rgb(var(--color-foreground));
  }
  
  /* Pause on hover */
  .marquee-wrapper:hover .marquee-track {
    animation-play-state: paused;
  }
  
  @keyframes marquee-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  
  @media (max-width: 768px) {
    .marquee-item span { font-size: 20px; }
    .marquee-item img { width: 55px; height: 55px; }
    .marquee-set { gap: 40px; padding-right: 40px; }
  }
{% endstyle %}

<section
  class="marquee-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding"
  id="marquee-{{ section.id }}"
  style="--marquee-speed: {{ section.settings.speed }}s;"
>
  <div class="marquee_main {% if section.settings.page_width %}page-width{% endif %}">
    <div class="marquee-wrapper">
      <div class="marquee-track">
        {% capture marquee_items %}
          {% for block in section.blocks %}
            <a href="{{ block.settings.link }}" class="marquee-item" {{ block.shopify_attributes }}>
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 200 | image_tag: fetchpriority: 'high' }}
              {% endif %}
              {% if block.settings.text != blank %}
                <span>{{ block.settings.text }}</span>
              {% endif %}
            </a>
          {% endfor %}
        {% endcapture %}

        {% for i in (1..4) %}
          <div class="marquee-set" aria-hidden="{% if i > 1 %}true{% else %}false{% endif %}">
            {{ marquee_items }}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Marquee Collections",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_top_border",
      "label": "Top Border"
    },
    {
      "type": "checkbox",
      "id": "show_bottom_border",
      "label": "Bottom Border"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "page_width",
      "label": "Enable Page Width",
      "default": false
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Marquee Direction",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Right to Left"
        },
        {
          "value": "right",
          "label": "Left to Right"
        }
      ]
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Speed (seconds)",
      "min": 5,
      "max": 60,
      "step": 1,
      "default": 18
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_top_mob",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mob",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Marquee Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "NEW : COLLECTION"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Collections",
      "blocks": [{ "type": "item" }, { "type": "item" }, { "type": "item" }]
    }
  ]
}
{% endschema %}
